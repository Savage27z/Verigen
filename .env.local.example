# Image generation
REPLICATE_API_TOKEN=

# Blockchain — Tatum Sui RPC
TATUM_API_KEY=
SUI_NETWORK=mainnet
NEXT_PUBLIC_SUI_NETWORK=mainnet  # Exposed to browser for explorer links
SUI_PRIVATE_KEY=          # Base64 encoded keypair for signing registry transactions
SUI_PACKAGE_ID=           # Published Move package address (from `sui client publish` output)
SUI_REGISTRY_OBJECT_ID=   # Deployed Move registry shared object ID

# AI Agent (OpenRouter — supports 200+ models)
OPENROUTER_API_KEY=

# Walrus
WALRUS_NETWORK=mainnet    # mainnet or testnet
WALRUS_EPOCHS=5           # Number of epochs to store blobs (default: 5)
